#! /usr/bin/env bash

## $Date$
## $Revision$

## TODO: Make it possible to run without internet access if expanded tarballs are already in place


## Choose to use stable tarballs or SVN versions of Rivet & AGILe
## You can also call this script like "DEVELOPERMODE=yes rivet-bootstrap"
if [[ -z "$DEVELOPERMODE" ]]; then
    DEVELOPERMODE="yes"
fi

## Build Python interface? True unless disabled.
if [[ -z "$USE_PYTHON" ]]; then
   USE_PYTHON="yes"
fi

## Use this flag to always bootstrap from source, even if AFS is found
## You can also call the script like "IGNORE_AFS=yes rivet-bootstrap"
if [[ -z "$IGNORE_AFS" ]]; then
    IGNORE_AFS="no"
fi

## Versions of AGILe and Rivet (if not in developer mode)
AGILE_VERSION=1.1.3
RIVET_VERSION=1.1.2

## configure options for AGILe
#AGILE_CONFIGURE_FLAGS=" --disable-ccherwig --disable-ccpythia --disable-sherpa"
AGILE_CONFIGURE_PATH="$PATH"

## Specify path to boost include dir if not found automatically
#BOOSTFLAGS=--with-boost=/usr/local/boost_1_35

## Versions of required libraries
LHAPDF_VERSION=5.6.0
FASTJET_VERSION=2.3.4
if [[ -z "$FASTJETJADE" ]]; then
    FASTJETJADE="yes"
fi
HEPMC_VERSION=2.04.00
PYHEPMC_VERSION=0.3.3

## Build and install to the PREFIX location
PREFIX=$PWD/local
test $# -eq 1 && PREFIX=$1
if test -z "$(echo $PREFIX | egrep '^/')"; then
    PREFIX=$PWD/$PREFIX
fi
mkdir -p $PREFIX
if ! test -w "$PREFIX"; then
    echo "Can't write to installation directory, $PREFIX" 1>&2
    echo "Exiting..." 1>&2
    exit 1
fi


## Set up Python install area
if test "$USE_PYTHON" == "yes"; then
    echo "Setting up Python library install area: must exist and be in \$PYTHONPATH"
    pyversion=$(python -c 'import sys; print "%d.%d" % (sys.version_info[0],sys.version_info[1])')
    libname="lib"
    if test "$(uname -m | grep "x86_64")"; then
        libname="lib64"
    fi
    pylibdir="$PREFIX/$libname/python$pyversion/site-packages"
    mkdir -p $pylibdir
    export PYTHONPATH=$PYTHONPATH:$pylibdir
    ## Flag to pass to AGILe and Rivet builds to enable Python extensions
    PYEXTFLAGS=--enable-pyext
fi


## Function to unpack and delete a tarball
wget-untargz() {
    ## Try first using wget, and falling back to trying curl (for Mac)
    WGETTER="wget --quiet -O-"
    if test ! -x "`which wget 2> /dev/null`"; then
        WGETTER="curl --silent"
        if test ! -x "`which curl 2> /dev/null`"; then
            echo "You need curl or wget to download the $tarname tarball" 1>&2
            exit 1
        fi
    fi
    ## Use whichever was present
    echo "Downloading: $WGETTER $1 | tar xzv"
    ($WGETTER $1 | tar xzv) || exit 1
}


## Function to enter an expanded tarball and run the usual
## autotools ./configure, make, make install mantra
conf-mk-mkinst() {
    if test -d $1; then
        (cd $1 && echo "./configure --prefix=$PREFIX" && \
            ./configure --prefix=$PREFIX --enable-shared --enable-pyext $2 && \
            make && make install) || exit 2
    else
        echo "Couldn't find $1... exiting"
        exit 1
    fi
}


##############################


## Get AGILe and Rivet either from released tarballs or SVN
## TODO: Remove AGILe from Rivet 1.1.3 onwards
if test "$DEVELOPERMODE" != "yes"; then
    ## USER MODE
    ## Get Rivet and AGILe tarballs (for non-developers)
    AGILE_NAME=AGILe-$AGILE_VERSION
    RIVET_NAME=Rivet-$RIVET_VERSION
    AGILE_URL=http://www.hepforge.org/archive/agile/$AGILE_NAME.tar.gz
    echo "Getting $AGILE_URL"
    wget-untargz $AGILE_URL
    ln -s $AGILE_NAME agile || exit 2
    RIVET_URL=http://www.hepforge.org/archive/rivet/$RIVET_NAME.tar.gz
    echo "Getting $RIVET_URL"
    wget-untargz $RIVET_URL
    ln -s $RIVET_NAME rivet || exit 2

else

    ## DEVELOPER MODE
    ## If we've got SVN and there are no already-checked out versions
    ## of AGILe and Rivet in this directory, then check out/update
    ## the SVN head versions using the HTTP access method
    for pkg in svn autoconf autoreconf automake libtool; do
        if test ! -x "`which $pkg 2> /dev/null`"; then
            echo "You must have $pkg installed to bootstrap in developer mode" 1>&2
            exit 1
        fi
    done


    ## Package checks done, let's bootstrap AGILe...
    if [[ ! -e agile ]]; then 
        svn co http://svn.hepforge.org/agile/trunk agile || exit 2
	else
	    svn update agile
    fi
    if [[ -e agile && ! -e agile/configure ]]; then 
        (cd agile && autoreconf -i) || exit 2
    fi

    ## ... and Rivet
    if [[ ! -e rivet ]]; then 
        svn co http://svn.hepforge.org/rivet/trunk rivet || exit 2        
	else
	    svn update rivet
    fi
    if [[ -e rivet && ! -e rivet/configure ]]; then 
        (cd rivet && autoreconf -i) || exit 2
    fi

fi


## Build Python HepMC interface if required
if test "$USE_PYTHON" == "yes"; then
    echo "Building Python HepMC interface"
    PYHEPMC_NAME=hepmc-python-$PYHEPMC_VERSION
    PYHEPMC_URL=http://www.hepforge.org/archive/rivet/$PYHEPMC_NAME.tar.gz
    echo "Getting $PYHEPMC_URL"
    wget-untargz "$PYHEPMC_URL"
    ln -s $PYHEPMC_NAME hepmc-python || exit 2
fi


## AFS directory where LCG external packages are installed
LCGDIR=/afs/cern.ch/sw/lcg/external


## Choose names for env files and determine user's default shell
SHENV=rivetenv.sh
CSHENV=rivetenv.csh
USERSHENV=$SHENV
if test -n $(which finger &> /dev/null); then
    USERSH=$(finger $USER | grep Shell | sed -e 's/.*Shell:\ *\(.*\)/\1/')
    if $(echo "$USERSH" | grep -i "csh" &> /dev/null); then
        USERSHENV=$CSHENV
    fi
fi


## Are we able to use pre-built packages from CERN AFS?
if test -d "$LCGDIR" && test "$IGNORE_AFS" != "yes"; then
    echo "LCG AFS area available: using LCG packages"

    ## Platform tag: get distribution
    distribution=$(uname)
    if test -s "/etc/redhat-release"; then
        distribution="redhat"
        sltest=$(lsb_release -ds | grep "Scientific Linux")
        if test "$sltest"; then
            slc_major=$(lsb_release -rs | cut -f1 -d.)
            distribution="slc${slc_major}"
        fi
    fi

    ## Platform tag: get architecture
    machine32=$(uname -m | grep -E "i[3456]86") 
    machine64=$(uname -m | grep "x86_64")
    if test "$machine32"; then machine="ia32"; fi 
    if test "$machine64"; then machine="amd64"; fi

    ## Platform tag: get GCC version
    gcc_version=$(g++ --version | head -1 | cut -d" " -f3)
    gcc_major=$(echo $gcc_version | cut -d. -f1)
    gcc_minor=$(echo $gcc_version | cut -d. -f2)
    gcc_micro=$(echo $gcc_version | cut -d. -f30) 
    gcc_code="gcc${gcc_major}${gcc_minor}"

    LCGPLATFORM="${distribution}_${machine}_${gcc_code}"
    echo "Using LCG platform tag = $LCGPLATFORM"


    HEPMCPATH=$LCGDIR/HepMC/$HEPMC_VERSION/$LCGPLATFORM 
    echo "HepMC path: $HEPMCPATH"
    FASTJETPATH=$LCGDIR/fastjet/$FASTJET_VERSION/$LCGPLATFORM 
    echo "FastJet path: $FASTJETPATH"
    LHAPDFPATH=$LCGDIR/MCGenerators/lhapdf/$LHAPDF_VERSION/$LCGPLATFORM
    echo "LHAPDF path: $LHAPDFPATH"
    export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$LHAPDFPATH/lib
    BOOST_VERSION=1.34.1
    BOOSTPATH=$LCGDIR/Boost/$BOOST_VERSION/$LCGPLATFORM
    BOOSTFLAGS=--with-boost-incpath=$BOOSTPATH/include/boost-${BOOST_VERSION//./_}
    echo "Compiling with: $BOOSTFLAGS"

    ## Enable C++ Pythia
    AGILE_CONFIGURE_FLAGS=" --enable-ccpythia"
    AGILE_CONFIGURE_FLAGS="$AGILE_CONFIGURE_FLAGS --with-pythia8=$LCGDIR/MCGenerators/pythia8/108/$LCGPLATFORM"


    ## Python interface
    if test "$USE_PYTHON" == "yes"; then
        echo "Building hepmc-python"
        cd hepmc-python
        echo "In $PWD"
        ./configure --prefix=$PREFIX \
            --with-hepmc=$HEPMCPATH || exit 2
        make || exit 2
        make install || exit 2
        cd ..
        echo "In $PWD"
        echo
    fi


    ## First AGILe
    echo "Building AGILe"
    echo "AGILE_CONFIGURE_FLAGS=$AGILE_CONFIGURE_FLAGS"
    echo "AGILE_CONFIGURE_PATH=$AGILE_CONFIGURE_PATH"
    cd agile
    echo "In $PWD"
    PATH=$AGILE_CONFIGURE_PATH ./configure --prefix=$PREFIX \
        --with-hepmc=$HEPMCPATH $BOOSTFLAGS $AGILE_CONFIGURE_FLAGS \
        $PYEXTFLAGS \
        || exit 2
    make || exit 2
    make install || exit 2
    cd ..
    echo "In $PWD"
    echo


    ## Then Rivet + rivetgun
    echo "Building Rivet"
    cd rivet
    echo "In $PWD"
    ## TODO: get Genser to link their Fortran generators using $(FC) rather than $(CXX), 
    ## then we can get rid of this nasty, fragile hack...
    LIB64=lib
    (echo $LCGPLATFORM | grep 64 &> /dev/null) && LIB64=lib64 
    GENSER_FC_STDLIBS="/usr/$LIB64/libgfortran.so.0 /usr/$LIB64/libg2c.so.0" 
    ## Finally, run configure...
    ./configure --prefix=$PREFIX \
        --with-hepmc=$HEPMCPATH \
        --with-fastjet=$FASTJETPATH \
        --with-agile=$PREFIX \
        $BOOSTFLAGS \
        $PYEXTFLAGS \
        LDFLAGS="$GENSER_FC_STDLIBS" || exit 2
    make || exit 2
    make install || exit 2
    cd ..
    echo "In $PWD"

    ## Write sh env file
    > $SHENV
    echo "export PATH=$PREFIX/bin:\$PATH" >> $SHENV
    echo "export LD_LIBRARY_PATH=$PREFIX/lib:$HEPMCPATH/lib:$FASTJETPATH/lib:$CGALPATH/lib:$LHAPDFPATH/lib:\$LD_LIBRARY_PATH" >> $SHENV
    if test "$USE_PYTHON" == "yes"; then
        echo "export PYTHONPATH=\$PYTHONPATH:$pylibdir" >> $SHENV
    fi

    ## Write csh env file
    > $CSHENV
    echo "setenv PATH $PREFIX/bin:\$PATH" >> $CSHENV
    echo "setenv LD_LIBRARY_PATH $PREFIX/lib:$HEPMCPATH/lib:$FASTJETPATH/lib:$CGALPATH/lib:$LHAPDFPATH/lib:\$LD_LIBRARY_PATH" >> $CSHENV
    if test "$USE_PYTHON" == "yes"; then
        echo "setenv PYTHONPATH \$PYTHONPATH:$pylibdir" >> $CSHENV
    fi

    #echo "export AGILE_GEN_PATH=$LCGDIR/MCGenerators/$LCGPLATFORM/lib"


else
    ## We don't have access to LCG AFS, so download the packages...

    ## Get LHAPDF
    LHAPDFNAME=lhapdf-$LHAPDF_VERSION
    test -d $LHAPDFNAME || wget-untargz http://www.hepforge.org/archive/lhapdf/$LHAPDFNAME.tar.gz || exit 2
    conf-mk-mkinst $LHAPDFNAME || exit 2

    ## Get HepMC
    HEPMCNAME=HepMC-$HEPMC_VERSION
    test -d $HEPMCNAME || wget-untargz http://lcgapp.cern.ch/project/simu/HepMC/download/$HEPMCNAME.tar.gz || exit 2
    conf-mk-mkinst $HEPMCNAME "--with-momentum=GEV --with-length=MM" || exit 2

    ## Get FastJet
    FASTJETNAME=fastjet-$FASTJET_VERSION
    test -d $FASTJETNAME || wget-untargz http://www.lpthe.jussieu.fr/~salam/repository/software/fastjet/$FASTJETNAME.tar.gz || exit 2
    if test "$FASTJETJADE" = "yes" -a -x "$(which autoreconf)"; then
        cd $FASTJETNAME
        if ! test -e "plugins/Jade"; then
            wget http://users.hepforge.org/~hoeth/fastjet/fastjet-2.3.4-jade.patch || exit 2
            patch -p1 < fastjet-2.3.4-jade.patch || exit 2
            autoreconf --install || exit 2
        fi;
        cd ..
    fi;
    conf-mk-mkinst $FASTJETNAME || exit 2


    ## Python interface
    if test "$USE_PYTHON" == "yes"; then
        #echo "Building hepmc-python"
        #cd hepmc-python
        #echo "In $PWD"
        #./configure --prefix=$PREFIX \
        #    --with-hepmc=$HEPMCPATH || exit 2
        #make || exit 2
        #make install || exit 2
        #cd ..
        #echo "In $PWD"
        #echo
        conf-mk-mkinst hepmc-python || exit 2
    fi


    ## Build and install AGILe
    ##conf-mk-mkinst agile || exit 2
    echo "Building AGILe"
    echo "AGILE_CONFIGURE_FLAGS=$AGILE_CONFIGURE_FLAGS"
    echo "AGILE_CONFIGURE_PATH=$AGILE_CONFIGURE_PATH"
    cd agile
    echo "In $PWD"
    PATH=$AGILE_CONFIGURE_PATH ./configure --prefix=$PREFIX \
        --with-hepmc=$HEPMCPATH $BOOSTFLAGS $PYEXTFLAGS $AGILE_CONFIGURE_FLAGS || exit 2
    make || exit 2
    make install || exit 2
    cd ..
    echo "In $PWD"
    echo


    ## Build and install Rivet
    test "$FASTJETJADE" = "yes" && RIVET_CONFIGURE_FLAGS="--enable-jade $PYEXTFLAGS"
    conf-mk-mkinst rivet $RIVET_CONFIGURE_FLAGS || exit 2

    ## Write sh env file
    > $SHENV
    echo "export PATH=$PREFIX/bin:\$PATH" >> $SHENV
    echo "export LD_LIBRARY_PATH=$PREFIX/lib:\$LD_LIBRARY_PATH" >> $SHENV
    if test "$USE_PYTHON" == "yes"; then
        echo "export PYTHONPATH=\$PYTHONPATH:$pylibdir" >> $SHENV
    fi

    ## Write csh env file
    > $CSHENV
    echo "setenv PATH $PREFIX/bin:\$PATH" >> $CSHENV
    echo "setenv LD_LIBRARY_PATH $PREFIX/lib:\$LD_LIBRARY_PATH" >> $CSHENV
    if test "$USE_PYTHON" == "yes"; then
        echo "setenv PYTHONPATH \$PYTHONPATH:$pylibdir" >> $CSHENV
    fi

fi


## Write environment variable information
echo
echo "All done. Now set some variables:"
cat $USERSHENV
echo "These variables are also written to $SHENV and $CSHENV, and"
echo "can be used in sh or csh shells respectively by sourcing, e.g."
echo ". $SHENV"
echo "or"
echo "source $CSHENV"


## Mention the AGILe Genser bootstrap to users not using AFS
if test ! -d "$LCGDIR" || test "$IGNORE_AFS" == "yes"; then
    echo 
    echo "You may also want to get a local copy of the Genser generators package"
    echo "and add its root directory to the AGILE_GEN_PATH variable."
    echo "The agile-genser-bootstrap script can help you to do this."
    echo "You can get it from"
    echo "http://svn.hepforge.org/agile/genser/agile-genser-bootstrap"
fi
